# ─────────────────────────────────────────────────────────────────────────────
# Vidyarthi Mitra — Professional Redesign Frontend · environment variables
# Copy this file to .env (or .env.local) and adjust the values.
# All VITE_* variables are embedded at build time by Vite.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL.
# Leave UNSET for local development: the Vite dev server proxies /api/v1 to
# http://localhost:5001 (see vite.config.js), so the app works with the
# existing backend running locally with no configuration.
# For production builds, set the deployed backend, e.g.:
# VITE_API_URL=https://private-universities-mern.onrender.com/api/v1

# Public site origin used for canonical URLs / OG tags (SEO).
# VITE_SITE_URL=https://privateuniversity.vidyarthimitra.org

# ── Vercel serverless SEO prerender (api/render.js) — server-side only ──
# Backend the bot-prerender function reads university data from.
# SEO_API_URL=https://private-universities-mern.onrender.com/api/v1
ADMIN_EMAIL=youremail@example.com